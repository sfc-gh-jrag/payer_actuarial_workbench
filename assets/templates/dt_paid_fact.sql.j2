CREATE OR REPLACE DYNAMIC TABLE {{ target('DT_PAID_FACT') }}
  TARGET_LAG = {% if params.target_lag == 'DOWNSTREAM' %}DOWNSTREAM{% else %}'{{ params.target_lag }}'{% endif %}
  WAREHOUSE = {{ warehouse }}
  REFRESH_MODE = {{ params.refresh_mode }}
  CLUSTER BY (line_of_business, incurred_month)
  COMMENT = 'Unified medical + Rx paid fact by LOB x constituent x service_category x incurred_month x paid_month. LOB attributed via equality join on materialized (member_id, incurred_month). Incremental.'
AS
WITH stg AS (
  SELECT member_id, constituent, service_category, incurred_month, paid_month, allowed_amt, paid_amt, service_units
  FROM {{ target('DT_MED_CLAIM_STG') }}
  UNION ALL
  SELECT member_id, constituent, service_category, incurred_month, paid_month, allowed_amt, paid_amt, service_units
  FROM {{ target('DT_RX_CLAIM_STG') }}
)
SELECT
  m.{{ c('MM_LINE_OF_BUSINESS') }}      AS line_of_business,
  s.constituent,
  s.service_category,
  s.incurred_month,
  s.paid_month,
  SUM(s.allowed_amt)                    AS allowed_amt,
  SUM(s.paid_amt)                       AS paid_amt,
  SUM(s.service_units)                  AS service_units,
  COUNT(*)                              AS claim_line_count
FROM stg s
JOIN {{ tbl('MM_MEMBER_ID') }} m
  ON s.member_id = m.{{ c('MM_MEMBER_ID') }}
 AND s.incurred_month = m.{{ c('MM_ELIGIBILITY_MONTH') }}
GROUP BY 1,2,3,4,5;

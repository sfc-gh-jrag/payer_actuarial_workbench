CREATE TABLE IF NOT EXISTS {{ target('WORK_PAPER_EVENT') }} (
  event_id        VARCHAR(40) NOT NULL PRIMARY KEY,
  work_paper_id   VARCHAR(40) NOT NULL,
  event_type      VARCHAR(30),   -- CREATE | BRANCH | STATUS_CHANGE | SIGN | FILE
  from_status     VARCHAR(20),
  to_status       VARCHAR(20),
  actor           VARCHAR(120),
  note            VARCHAR(2000),
  created_at      TIMESTAMP_NTZ DEFAULT CURRENT_TIMESTAMP()
) CLUSTER BY (work_paper_id)
  COMMENT = 'Append-only audit trail of work-paper lifecycle events (ASOP 41). Written by the SP_*_WORK_PAPER procedures.';
